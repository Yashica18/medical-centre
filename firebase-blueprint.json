{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Appointment": {
      "title": "Appointment Booking",
      "description": "Details of a booked doctor appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "patientName": { "type": "string" },
        "patientEmail": { "type": "string" },
        "patientPhone": { "type": "string" },
        "departmentId": { "type": "string" },
        "doctorId": { "type": "string" },
        "date": { "type": "string" },
        "timeSlot": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Confirmed", "Cancelled"] },
        "createdAt": { "type": "string" },
        "emailNotificationsEnabled": { "type": "boolean" }
      },
      "required": ["id", "userId", "patientName", "patientEmail", "patientPhone", "departmentId", "doctorId", "date", "timeSlot", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "The user document for a given patient user ID"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Global appointment bookings, queryable by user or by confirmation code"
    }
  }
}
